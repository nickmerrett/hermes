# Core API Keys (Required)
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Optional, only if using OpenAI provider
NEWS_API_KEY=your_newsapi_key_here

# Social Media API Keys (Optional - enable specific collectors)
# Reddit API (free, get at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=CustomerIntelligenceTool/1.0

# Twitter API v2 (requires Twitter Developer account)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# GitHub API (optional, increases rate limits)
GITHUB_TOKEN=your_github_personal_access_token_here

# YouTube API (optional, for video intelligence)
YOUTUBE_API_KEY=your_youtube_api_key_here

# LinkedIn (optional, third-party service like Proxycurl)
PROXYCURL_API_KEY=your_proxycurl_api_key_here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# Timezone (use your local timezone, e.g., America/New_York, Europe/London, Australia/Sydney)
# List of timezones: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Database
DATABASE_PATH=data/db/intelligence.db
CHROMA_PATH=data/chroma

# Scheduler Settings
ENABLE_SCHEDULER=true
HOURLY_COLLECTION_ENABLED=true
DAILY_COLLECTION_ENABLED=true
DAILY_COLLECTION_HOUR=10  # Hour (0-23) to run daily comprehensive collection in container timezone

# AI Processing

# ============================================================================
# OPTION 1: Use Prompt Template System (RECOMMENDED)
# ============================================================================
# Define all prompts and their models in one YAML file with per-prompt model assignment
# Templates are in backend/config/prompts/ directory
# Each template defines all 7 required prompts with their specific model configurations
#
# Example templates:
# - qwen3-4b.yaml: Uses local Qwen 3 VL 4B for article processing, Claude Haiku for summaries
# - claude.yaml: Uses Claude Sonnet for daily summaries, Haiku for article processing
# - granite-4-micro.yaml: Uses IBM Granite 4.0 H Micro via LM Studio
#
# Provide full path to template file:
#   - Docker: /app/config/prompts/claude.yaml
#   - Local: config/prompts/claude.yaml
#   - Custom: /absolute/path/to/template.yaml
#
# If AI_PROMPT_TEMPLATE is set, all settings below are ignored
AI_PROMPT_TEMPLATE=  # Full path to template file. Leave empty to use Option 2

# ============================================================================
# OPTION 2: Individual Model Configuration (Legacy, still supported)
# ============================================================================
# Only used if AI_PROMPT_TEMPLATE is empty
# Provider selection: anthropic or openai (supports OpenAI API, LM Studio, Ollama, etc.)
AI_PROVIDER=anthropic
AI_PROVIDER_CHEAP=anthropic

# Model configuration (uses env vars by default, UI can override if MODEL_OVERRIDE_IN_UI=true)
# Anthropic models: claude-sonnet-4-5-20250929 (newest), claude-haiku-4-5-20250929 (fast), claude-opus-4-1-20250805 (most capable)
# OpenAI models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
AI_MODEL=claude-sonnet-4-5-20250929  # Premium model for daily summaries and complex tasks
AI_MODEL_TIER=frontier  # Prompt complexity: "frontier" (advanced models) or "small" (basic models, local LLMs)
AI_MODEL_CHEAP=claude-haiku-4-5-20250929  # Economy model for entity extraction, filtering, article summaries
AI_MODEL_TIER_CHEAP=small  # Prompt complexity for economy model: "frontier" or "small"
MODEL_OVERRIDE_IN_UI=false  # Set to 'true' to allow UI Settings page to override model configuration

# API Base URLs (can override for proxies, LM Studio, Ollama, etc.)
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
OPENAI_BASE_URL=https://api.openai.com/v1

# Other AI settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_TOKENS_SUMMARY=800

# API Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:8000

# Rate Limiting
NEWS_API_RATE_LIMIT=100
CLAUDE_API_RATE_LIMIT=50

# Data Retention
INTELLIGENCE_RETENTION_DAYS=90

# API Base URLs (Advanced - override for proxies/testing)
# HackerNews API (Algolia HN Search)
HACKERNEWS_API_BASE_URL=https://hn.algolia.com/api/v1

# LinkedIn Base URL (for Playwright scraper)
LINKEDIN_BASE_URL=https://www.linkedin.com

# LinkedIn Playwright Authentication (Optional - for logged-in scraping)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_HEADLESS=true
