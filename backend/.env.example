# Hermes Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# AI & Processing
# =============================================================================

# AI Provider Configuration
# Choose which AI provider to use for each tier: anthropic or openai
AI_PROVIDER=anthropic           # Provider for premium model (daily summaries)
AI_PROVIDER_CHEAP=anthropic     # Provider for economy model (article processing)

# Premium Model (Daily Summaries)
# Used for daily briefings and complex analysis tasks
AI_MODEL=claude-sonnet-4-5-20250929

# Economy Model (Article Processing)
# Used for entity extraction, filtering, and article summaries (high volume)
AI_MODEL_CHEAP=claude-haiku-4-5-20250929

# Anthropic Configuration
# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# OpenAI Configuration (if using AI_PROVIDER=openai or AI_PROVIDER_CHEAP=openai)
# Get API key from: https://platform.openai.com/api-keys
# Base URL supports: OpenAI, Azure OpenAI, LM Studio, Ollama, Together AI, Groq, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Examples for OpenAI-compatible providers:
# LM Studio (local):   OPENAI_BASE_URL=http://localhost:1234/v1
# Ollama (local):      OPENAI_BASE_URL=http://localhost:11434/v1
# Together AI:         OPENAI_BASE_URL=https://api.together.xyz/v1
# Groq:                OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Embedding Model (for semantic search and clustering)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# News & Data Collection APIs
# =============================================================================

# News API Key (Optional - for general news)
# Get from: https://newsapi.org/
NEWS_API_KEY=

# =============================================================================
# Social Media & Platform APIs
# =============================================================================

# Reddit API (Optional - for Reddit monitoring)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CustomerIntelligenceTool/1.0

# Twitter/X API (Optional - for Twitter monitoring)
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=

# YouTube Data API (Optional - for YouTube video transcript monitoring)
# Get from: https://console.cloud.google.com/ (Enable YouTube Data API v3)
YOUTUBE_API_KEY=

# Gmail OAuth (Optional - for press release digest monitoring)
# Get from: https://console.cloud.google.com/
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: http://localhost:8000/api/gmail/oauth/callback
# 3. Enable Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/gmail/oauth/callback

# Encryption key for storing OAuth tokens securely
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# GitHub API (Optional - for GitHub monitoring)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=

# =============================================================================
# LinkedIn Scraping (Optional)
# =============================================================================

# LinkedIn credentials for authenticated scraping via Playwright
# WARNING: Use at your own risk - LinkedIn may ban accounts for scraping
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_HEADLESS=true

# =============================================================================
# Authentication (JWT)
# =============================================================================

# JWT Secret Key (REQUIRED for auth)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# JWT Token Expiration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap Admin Account (created on first startup if no users exist)
# IMPORTANT: Change password immediately after first login!
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme123

# =============================================================================
# Application Settings
# =============================================================================

# Environment
APP_ENV=development
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma-separated)
# Add your Kubernetes/production domain here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://hermes.apps.homeserv.merrett.lan,https://hermes.apps.homeserv.merrett.lan

# =============================================================================
# Database & Storage
# =============================================================================

# Database Path
DATABASE_PATH=data/db/intelligence.db

# Vector Store Path
CHROMA_PATH=data/chroma

# =============================================================================
# Scheduler & Collection
# =============================================================================

# Enable/Disable Scheduler
ENABLE_SCHEDULER=true

# Hourly Collection
HOURLY_COLLECTION_ENABLED=true

# Daily Collection
DAILY_COLLECTION_ENABLED=true
DAILY_COLLECTION_HOUR=10

# =============================================================================
# Data Retention
# =============================================================================

# Intelligence Item Retention (days)
INTELLIGENCE_RETENTION_DAYS=90

# =============================================================================
# Rate Limiting
# =============================================================================

NEWS_API_RATE_LIMIT=100
CLAUDE_API_RATE_LIMIT=50

# =============================================================================
# Timezone
# =============================================================================

# Server Timezone (for scheduled jobs)
TZ=Australia/Sydney
