def main():
    """Main CLI entry point"""
    # We already parsed early for --debug flag at module level
    # Now create the full parser
    full_parser = argparse.ArgumentParser(
        description='Hermes Diagnostics CLI - Debugging and monitoring tool',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  ./hermes-diag sources                    # Show collection statistics
  ./hermes-diag config                     # Check customer configuration
  ./hermes-diag reddit                     # Check Reddit items
  ./hermes-diag api-feed "ANZ Bank"        # Test API feed for ANZ Bank
  ./hermes-diag import-config              # Import from config/customers.yaml to DB
  ./hermes-diag import-config -f backup.yaml # Import from custom YAML file
  ./hermes-diag export-config              # Export from DB to config/customers.yaml
  ./hermes-diag export-config -f backup.yaml # Export to custom YAML file
  ./hermes-diag export-config --force      # Skip confirmation
  ./hermes-diag backfill-clustering        # Cluster all unclustered items
  ./hermes-diag backfill-clustering --force # Skip confirmation
  ./hermes-diag linkedin-dates             # Check LinkedIn post dates and age
  ./hermes-diag rebuild-vectors            # Rebuild vector store from scratch
  ./hermes-diag rebuild-vectors --force    # Skip confirmation
  ./hermes-diag delete-linkedin-posts      # Delete ALL LinkedIn posts (DESTRUCTIVE)
  ./hermes-diag delete-linkedin-profiles   # Delete LinkedIn profile items only
  ./hermes-diag all                        # Run all diagnostics
  ./hermes-diag --debug sources            # Show SQL queries (debug mode)
        """
    )

    # Add global --debug flag
    full_parser.add_argument(
        '--debug',
        action='store_true',
        help='Show SQL queries and verbose logging'
    )

    subparsers = full_parser.add_subparsers(dest='command', help='Available commands')

    # sources command
    subparsers.add_parser('sources', help='Show collection statistics by source type')

    # config command
    subparsers.add_parser('config', help='Check customer configuration in database')

    # reddit command
    subparsers.add_parser('reddit', help='Check Reddit items and clustering status')

    # reddit-processed command
    subparsers.add_parser('reddit-processed', help='Check Reddit processing status')

    # api-feed command
    api_parser = subparsers.add_parser('api-feed', help='Test API feed endpoint')
    api_parser.add_argument('customer', nargs='?', help='Customer name to test (optional)')

    # import-config command
    import_parser = subparsers.add_parser('import-config', help='Import customer config from YAML to database')
    import_parser.add_argument('--file', '-f', type=str, help='Path to YAML file to import (default: config/customers.yaml)')

    # export-config command
    export_parser = subparsers.add_parser('export-config', help='Export customer config from database to YAML')
    export_parser.add_argument('--file', '-f', type=str, help='Path to output YAML file (default: config/customers.yaml)')
    export_parser.add_argument('--force', action='store_true', help='Skip confirmation prompt')

    # backfill-clustering command
    backfill_parser = subparsers.add_parser('backfill-clustering', help='Cluster all unclustered items in database')
    backfill_parser.add_argument('--force', action='store_true', help='Skip confirmation prompt')

    # linkedin-dates command
    subparsers.add_parser('linkedin-dates', help='Check LinkedIn post dates and age')

    # rebuild-vectors command
    rebuild_parser = subparsers.add_parser('rebuild-vectors', help='Rebuild vector store from scratch')
    rebuild_parser.add_argument('--force', action='store_true', help='Skip confirmation prompt')

    # delete-linkedin-posts command (DESTRUCTIVE)
    delete_posts_parser = subparsers.add_parser('delete-linkedin-posts', help='Delete ALL LinkedIn posts (DESTRUCTIVE)')
    delete_posts_parser.add_argument('--force', action='store_true', help='Skip confirmation prompt')

    # delete-linkedin-profiles command (DESTRUCTIVE)
    delete_profiles_parser = subparsers.add_parser('delete-linkedin-profiles', help='Delete LinkedIn profile items only (DESTRUCTIVE)')
    delete_profiles_parser.add_argument('--force', action='store_true', help='Skip confirmation prompt')

    # all command
    subparsers.add_parser('all', help='Run all diagnostics')

    args = full_parser.parse_args()

    # Logging was already configured at module level based on --debug flag

    if not args.command:
        full_parser.print_help()
        sys.exit(1)

    # Route to appropriate command handler
    commands = {
        'sources': cmd_sources,
        'config': cmd_config,
        'reddit': cmd_reddit,
        'reddit-processed': cmd_reddit_processed,
        'api-feed': cmd_api_feed,
        'import-config': cmd_import_config,
        'export-config': cmd_export_config,
        'backfill-clustering': cmd_backfill_clustering,
        'linkedin-dates': cmd_linkedin_dates,
        'rebuild-vectors': cmd_rebuild_vectors,
        'delete-linkedin-posts': cmd_delete_linkedin_posts,
        'delete-linkedin-profiles': cmd_delete_linkedin_profiles,
        'all': cmd_all,
    }

    handler = commands.get(args.command)
    if handler:
        handler(args)
    else:
        full_parser.print_help()
        sys.exit(1)


if __name__ == '__main__':
    main()
