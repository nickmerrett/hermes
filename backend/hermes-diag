#!/usr/bin/env python3
"""
Hermes Diagnostics CLI Tool

A unified diagnostic tool for debugging and monitoring the Hermes intelligence platform.

Usage:
    ./hermes-diag sources                    # Show collection statistics by source
    ./hermes-diag config                     # Check customer configuration
    ./hermes-diag reddit                     # Check Reddit items and clustering
    ./hermes-diag reddit-processed           # Check Reddit processing status
    ./hermes-diag api-feed [customer]        # Test API feed endpoint
    ./hermes-diag import-config              # Import from config/customers.yaml → Database
    ./hermes-diag import-config -f backup.yaml # Import from custom YAML file
    ./hermes-diag export-config              # Export from Database → config/customers.yaml
    ./hermes-diag export-config -f backup.yaml # Export to custom YAML file
    ./hermes-diag export-config --force      # Skip confirmation prompt
    ./hermes-diag backfill-clustering        # Cluster all unclustered items
    ./hermes-diag backfill-clustering --force # Skip confirmation prompt
    ./hermes-diag all                        # Run all diagnostics
    ./hermes-diag --debug sources            # Show SQL queries (debug mode)
"""

import sys
import argparse
import logging
sys.path.insert(0, 'backend')

# Parse arguments FIRST to determine debug mode
# We need to configure logging BEFORE importing database modules
parser = argparse.ArgumentParser(add_help=False)
parser.add_argument('--debug', action='store_true')
early_args, _ = parser.parse_known_args()

# Configure SQLAlchemy logging BEFORE importing modules
if not early_args.debug:
    # Suppress ALL SQLAlchemy logging (quiet mode)
    # Use .disabled = True to completely disable logging even when echo=True on engine
    logging.getLogger('sqlalchemy.engine').disabled = True
    logging.getLogger('sqlalchemy.pool').disabled = True
    logging.getLogger('sqlalchemy.dialects').disabled = True
    logging.getLogger('sqlalchemy.orm').disabled = True
else:
    # Debug mode - enable SQLAlchemy logging
    logging.basicConfig(level=logging.INFO)
    logging.getLogger('sqlalchemy.engine').setLevel(logging.INFO)
    logging.getLogger('sqlalchemy.engine').disabled = False

# NOW import database modules
from app.core.database import SessionLocal
from app.models.database import IntelligenceItem, ProcessedIntelligence, Customer
from app.scheduler.collection import sync_customers_to_db, export_customers_to_yaml
from sqlalchemy import func, desc, and_
from datetime import datetime, timedelta
import time


class Colors:
    """ANSI color codes for terminal output"""
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'


def print_header(text):
    """Print a formatted header"""
    print(f"\n{Colors.BOLD}{Colors.CYAN}{'='*60}{Colors.ENDC}")
    print(f"{Colors.BOLD}{Colors.CYAN}{text}{Colors.ENDC}")
    print(f"{Colors.BOLD}{Colors.CYAN}{'='*60}{Colors.ENDC}\n")


def print_success(text):
    """Print success message"""
    print(f"{Colors.GREEN}✅ {text}{Colors.ENDC}")


def print_error(text):
    """Print error message"""
    print(f"{Colors.RED}❌ {text}{Colors.ENDC}")


def print_warning(text):
    """Print warning message"""
    print(f"{Colors.YELLOW}⚠️  {text}{Colors.ENDC}")


def print_info(text):
    """Print info message"""
    print(f"{Colors.BLUE}ℹ️  {text}{Colors.ENDC}")


def cmd_sources(args):
    """Show collection statistics by source type"""
    print_header("Database Sources Check")

    db = SessionLocal()
    try:
        # Total items
        total_items = db.query(IntelligenceItem).count()
        print(f"📊 Total items in database: {Colors.BOLD}{total_items}{Colors.ENDC}\n")

        if total_items == 0:
            print_warning("No items in database yet")
            print("\nTo collect items:")
            print("  curl -X POST http://localhost:8000/api/jobs/trigger")
            return

        # Items by source type
        print_header("Items by Source Type")

        source_stats = db.query(
            IntelligenceItem.source_type,
            func.count(IntelligenceItem.id).label('count')
        ).group_by(
            IntelligenceItem.source_type
        ).order_by(
            func.count(IntelligenceItem.id).desc()
        ).all()

        for source_type, count in source_stats:
            percentage = (count / total_items) * 100
            print(f"  {source_type:20s} {count:4d} items ({percentage:5.1f}%)")

        # Items by customer
        print_header("Items by Customer")

        customer_stats = db.query(
            Customer.name,
            func.count(IntelligenceItem.id).label('count')
        ).join(
            IntelligenceItem
        ).group_by(
            Customer.name
        ).order_by(
            func.count(IntelligenceItem.id).desc()
        ).all()

        for customer_name, count in customer_stats:
            percentage = (count / total_items) * 100
            print(f"  {customer_name:20s} {count:4d} items ({percentage:5.1f}%)")

        # Recent items (last 24 hours)
        print_header("Recent Items (Last 24 Hours)")

        cutoff = datetime.utcnow() - timedelta(hours=24)
        recent_stats = db.query(
            IntelligenceItem.source_type,
            func.count(IntelligenceItem.id).label('count')
        ).filter(
            IntelligenceItem.collected_date >= cutoff
        ).group_by(
            IntelligenceItem.source_type
        ).order_by(
            func.count(IntelligenceItem.id).desc()
        ).all()

        if recent_stats:
            for source_type, count in recent_stats:
                print(f"  {source_type:20s} {count:4d} items")
        else:
            print("  No items collected in last 24 hours")

        # Clustering stats
        print_header("Clustering Statistics")

        clustered_count = db.query(IntelligenceItem).filter(
            IntelligenceItem.cluster_id.isnot(None)
        ).count()

        unique_clusters = db.query(
            func.count(func.distinct(IntelligenceItem.cluster_id))
        ).filter(
            IntelligenceItem.cluster_id.isnot(None)
        ).scalar()

        multi_source_clusters = db.query(
            IntelligenceItem.cluster_id
        ).filter(
            IntelligenceItem.cluster_id.isnot(None)
        ).group_by(
            IntelligenceItem.cluster_id
        ).having(
            func.count(IntelligenceItem.id) > 1
        ).count()

        print(f"  Clustered items: {clustered_count}/{total_items} ({clustered_count/total_items*100:.1f}%)")
        print(f"  Unique clusters: {unique_clusters}")
        print(f"  Multi-source stories: {multi_source_clusters}")
        print(f"  Single-source stories: {unique_clusters - multi_source_clusters}")

    except Exception as e:
        print_error(f"Error: {e}")
        import traceback
        traceback.print_exc()
    finally:
        db.close()


