def cmd_export_config(args):
    """Export customer config from database to YAML"""
    print_header("Export Customer Config (Database → YAML)")

    db = SessionLocal()
    try:
        # Use custom path if provided, otherwise use default from settings
        if args.file:
            output_path = args.file
        else:
            from app.config.settings import settings
            output_path = settings.customers_config_path

        # Get customer name filter if provided
        customer_name = getattr(args, 'customer', None)

        # Query customers based on filter
        if customer_name:
            customers = db.query(Customer).filter(Customer.name.ilike(f"%{customer_name}%")).all()
            if not customers:
                print_error(f"Customer '{customer_name}' not found in database")
                return
            if len(customers) > 1:
                print_error(f"Multiple customers match '{customer_name}':")
                for customer in customers:
                    print(f"   - {customer.name}")
                print("\nPlease be more specific.")
                return
            print(f"📊 Found customer: {customers[0].name}")
        else:
            customers = db.query(Customer).all()
            if not customers:
                print_warning("No customers in database to export")
                return
            print(f"📊 Found {len(customers)} customers in database")
            for customer in customers:
                print(f"   - {customer.name}")

        # Check if file exists
        import os
        if os.path.exists(output_path):
            file_exists_msg = f"\n{Colors.YELLOW}⚠️  File already exists: {output_path}{Colors.ENDC}"
        else:
            file_exists_msg = f"\n📝 Will create new file: {output_path}"

        # Confirm with user
        if not args.force:
            print(file_exists_msg)
            response = input("Proceed? (yes/no): ")
            if response.lower() not in ['yes', 'y']:
                print_error("Export cancelled")
                return

        if customer_name:
            print(f"\n🔄 Exporting customer '{customers[0].name}' to {output_path}...\n")
        else:
            print(f"\n🔄 Exporting {len(customers)} customers to {output_path}...\n")

        export_path = export_customers_to_yaml(db, output_path, customer_name)

        if customer_name:
            print_success(f"Export complete! Wrote customer '{customers[0].name}' to {export_path}")
        else:
            print_success(f"Export complete! Wrote {len(customers)} customers to {export_path}")

        # Show summary
        print(f"\n📝 Exported configuration:")
        for customer in customers:
            config = customer.config or {}
            print(f"\n{Colors.BOLD}Customer: {customer.name}{Colors.ENDC}")
            print(f"  Keywords: {len(customer.keywords or [])} items")
            print(f"  Competitors: {len(customer.competitors or [])} items")
            print(f"  Priority keywords: {len(config.get('priority_keywords', []))} items")
            print(f"  Reddit subreddits: {len(config.get('reddit_subreddits', []))} items")
            print(f"  YouTube channels: {len(config.get('youtube_channels', []))} items")
            print(f"  RSS feeds: {len(config.get('rss_feeds', []))} items")
            print(f"  LinkedIn profiles: {len(config.get('linkedin_user_profiles', []))} items")
            print(f"  Web scrape sources: {len(config.get('web_scrape_sources', []))} items")

    except Exception as e:
        print_error(f"Error: {e}")
        import traceback
        traceback.print_exc()
    finally:
        db.close()

    print(f"\n{Colors.BOLD}{'='*60}{Colors.ENDC}")
    print_success("Config exported from database to YAML!")


def cmd_linkedin_dates(args):
    """Check LinkedIn post dates and age"""
    print_header("LinkedIn Post Dates Check")

    db = SessionLocal()
    try:
        # Get most recent LinkedIn posts
        posts = db.query(IntelligenceItem).filter(
            IntelligenceItem.source_type == 'linkedin_user'
        ).order_by(IntelligenceItem.id.desc()).limit(10).all()

        if not posts:
            print_warning("No LinkedIn posts found in database")
            return

        print(f"Found {Colors.BOLD}{len(posts)}{Colors.ENDC} LinkedIn posts")
        print(f"Current time: {datetime.utcnow()} UTC\n")

        for i, post in enumerate(posts, 1):
            print(f"{Colors.BOLD}{i}. {post.title[:80]}...{Colors.ENDC}")
            print(f"   ID: {post.id}")
            print(f"   Published: {post.published_date}")
            print(f"   Collected: {post.collected_date}")

            # Calculate age
            if post.published_date:
                age = datetime.utcnow() - post.published_date
                days = age.days
                hours = age.seconds // 3600
                print(f"   Age: {days} days, {hours} hours ago")

            if post.raw_data and 'author' in post.raw_data:
                print(f"   Author: {post.raw_data['author']}")

            print()

    except Exception as e:
        print_error(f"Error checking dates: {e}")
        import traceback
        traceback.print_exc()

    finally:
        db.close()


def cmd_rebuild_vectors(args):
