def cmd_backfill_clustering(args):
    """Backfill clustering for existing unclustered items"""
    print_header("Story Clustering Backfill")

    # Import here to avoid loading if not needed
    from app.core.vector_store import get_vector_store
    from app.utils.clustering import cluster_item, find_similar_cluster

    db = SessionLocal()

    try:
        vector_store = get_vector_store()

        # Get total item count
        total_items = db.query(IntelligenceItem).count()
        print(f"📊 Total items in database: {Colors.BOLD}{total_items}{Colors.ENDC}\n")

        if total_items == 0:
            print_warning("No items to cluster")
            return

        # Get unclustered items
        unclustered_items = db.query(IntelligenceItem).filter(
            IntelligenceItem.cluster_id.is_(None)
        ).order_by(
            IntelligenceItem.collected_date.desc()
        ).all()

        unclustered_count = len(unclustered_items)
        print(f"📋 Unclustered items: {unclustered_count}")

        if unclustered_count == 0:
            print_success("All items are already clustered!")
            return

        # Confirm with user
        if not args.force:
            print(f"\n{Colors.YELLOW}⚠️  This will cluster {unclustered_count} items.{Colors.ENDC}")
            response = input("Proceed? (yes/no): ")
            if response.lower() not in ['yes', 'y']:
                print_error("Backfill cancelled")
                return

        print(f"\n🔄 Starting clustering process...")
        print(f"   This may take ~{int(unclustered_count * 0.2)} seconds\n")

        start_time = time.time()
        clustered_count = 0
        error_count = 0
        created_clusters = 0
        joined_clusters = 0

        # Process items
        for i, item in enumerate(unclustered_items):
            try:
                # Get embedding
                embedding = vector_store.get_embedding(item.id)

                if not embedding:
                    print_warning(f"No embedding for item {item.id}: {item.title[:50]}...")
                    error_count += 1
                    continue

                if item.cluster_id:
                    continue

                # Check if joining existing cluster
                existing_cluster = find_similar_cluster(
                    item_embedding=embedding,
                    customer_id=item.customer_id,
                    published_date=item.published_date or item.collected_date,
                    db=db,
                    similarity_threshold=0.50,
                    time_window_hours=96
                )

                # Cluster the item
                cluster_item(
                    item=item,
                    item_embedding=embedding,
                    db=db,
                    similarity_threshold=0.50
                )

                clustered_count += 1

                if existing_cluster:
                    joined_clusters += 1
                else:
                    created_clusters += 1

                # Show progress
                if clustered_count % 20 == 0:
                    progress = (clustered_count / unclustered_count) * 100
                    elapsed = time.time() - start_time
                    rate = clustered_count / elapsed if elapsed > 0 else 0
                    remaining = (unclustered_count - clustered_count) / rate if rate > 0 else 0

                    print(f"   Progress: {clustered_count}/{unclustered_count} ({progress:.1f}%) "
                          f"| {rate:.1f} items/sec | ~{int(remaining)}s remaining")

            except Exception as e:
                print_error(f"Error clustering item {item.id}: {e}")
                error_count += 1
                continue

        elapsed_time = time.time() - start_time

        # Results
        print_header("Backfill Complete!")

        print(f"📈 Results:")
        print(f"   {Colors.GREEN}✅ Successfully clustered: {clustered_count} items{Colors.ENDC}")
        print(f"   🆕 New clusters created: {created_clusters}")
        print(f"   🔗 Items joined existing clusters: {joined_clusters}")
        if error_count > 0:
            print(f"   {Colors.RED}❌ Errors: {error_count}{Colors.ENDC}")
        print(f"   ⏱️  Time taken: {elapsed_time:.1f} seconds")
        print(f"   ⚡ Speed: {clustered_count / elapsed_time:.1f} items/second")

        # Cluster statistics
        total_clusters = db.query(func.count(func.distinct(IntelligenceItem.cluster_id))).filter(
            IntelligenceItem.cluster_id.isnot(None)
        ).scalar()

        multi_item_clusters = db.query(
            func.count(func.distinct(IntelligenceItem.cluster_id))
        ).filter(
            IntelligenceItem.cluster_id.isnot(None)
        ).group_by(
            IntelligenceItem.cluster_id
        ).having(
            func.count(IntelligenceItem.id) > 1
        ).count()

        print(f"\n📊 Cluster Statistics:")
        print(f"   Total clusters: {total_clusters}")
        print(f"   Multi-source stories: {multi_item_clusters}")
        print(f"   Unique stories: {total_clusters - multi_item_clusters}")

        # Example clusters
        print(f"\n💡 Example multi-source stories:")

        examples = db.query(
            IntelligenceItem.cluster_id,
            func.count(IntelligenceItem.id).label('count')
        ).filter(
            IntelligenceItem.cluster_id.isnot(None)
        ).group_by(
            IntelligenceItem.cluster_id
        ).having(
            func.count(IntelligenceItem.id) > 1
        ).order_by(
            func.count(IntelligenceItem.id).desc()
        ).limit(5).all()

        for cluster_id, count in examples:
            items = db.query(IntelligenceItem).filter(
                IntelligenceItem.cluster_id == cluster_id
            ).all()

            primary = next((i for i in items if i.is_cluster_primary), items[0])
            sources = list(set([i.source_type for i in items]))

            print(f"\n   📰 {primary.title[:70]}...")
            print(f"      {count} sources: {', '.join(sources)}")

        print_success("\nBackfill complete! Feed is now clustered.")

    except Exception as e:
        print_error(f"Backfill failed: {e}")
        import traceback
        traceback.print_exc()

    finally:
        db.close()


def cmd_linkedin_login(args):
