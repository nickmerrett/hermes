def cmd_rebuild_vectors(args):
    """Rebuild vector store from scratch"""
    print_header("Rebuild Vector Store")

    # Import here to avoid loading if not needed
    from app.core.vector_store import get_vector_store

    vector_store = get_vector_store()
    current_count = vector_store.get_item_count()

    print(f"Current vector store items: {Colors.BOLD}{current_count}{Colors.ENDC}\n")

    db = SessionLocal()
    try:
        # Count database items
        db_count = db.query(IntelligenceItem).count()
        print(f"Database items: {Colors.BOLD}{db_count}{Colors.ENDC}\n")

        # Confirm with user
        if not args.force:
            print(f"{Colors.YELLOW}⚠️  This will delete and rebuild the entire vector store.{Colors.ENDC}")
            print(f"   This process will:")
            print(f"   - Delete all {current_count} existing embeddings")
            print(f"   - Re-embed all {db_count} items from database")
            print(f"   - Take approximately {int(db_count * 0.5)} seconds\n")
            response = input("Proceed? (yes/no): ")
            if response.lower() not in ['yes', 'y']:
                print_error("Rebuild cancelled")
                return

        print(f"\n🔄 Resetting vector store...")
        vector_store.reset()
        print_success("Vector store reset complete")

        # Get all items
        items = db.query(IntelligenceItem).all()
        print(f"\n📊 Found {len(items)} items in database")

        if not items:
            print_warning("No items to add")
            return

        # Prepare batches
        item_ids = []
        texts = []
        metadatas = []

        print("\n🔄 Preparing embeddings...")
        for item in items:
            text_for_embedding = f"{item.title}\n\n{item.content or ''}"

            item_ids.append(item.id)
            texts.append(text_for_embedding)
            metadatas.append({
                'customer_id': item.customer_id,
                'source_type': item.source_type,
            })

        # Add in batches
        batch_size = 100
        total_batches = (len(item_ids) + batch_size - 1) // batch_size

        for i in range(0, len(item_ids), batch_size):
            batch_ids = item_ids[i:i+batch_size]
            batch_texts = texts[i:i+batch_size]
            batch_metadatas = metadatas[i:i+batch_size]

            vector_store.add_items_batch(batch_ids, batch_texts, batch_metadatas)

            batch_num = i // batch_size + 1
            print(f"   Batch {batch_num}/{total_batches} complete ({len(batch_ids)} items)")

        final_count = vector_store.get_item_count()
        print(f"\n{Colors.GREEN}✓ Vector store rebuilt successfully!{Colors.ENDC}")
        print(f"   Total items: {final_count}")

        # Test search
        print(f"\n🔍 Testing search...")
        results = vector_store.search("test query", n_results=5)
