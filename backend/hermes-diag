def cmd_reddit(args):
    """Check Reddit items and clustering status"""
    print_header("Reddit Items Diagnostic")

    db = SessionLocal()
    try:
        # Get all Reddit items
        reddit_items = db.query(IntelligenceItem).filter(
            IntelligenceItem.source_type == 'reddit'
        ).all()

        print(f"Total Reddit items: {Colors.BOLD}{len(reddit_items)}{Colors.ENDC}\n")

        if not reddit_items:
            print_warning("No Reddit items found in database")
            return

        # Check clustering status
        primary_count = sum(1 for item in reddit_items if item.is_cluster_primary)
        clustered_count = sum(1 for item in reddit_items if item.cluster_id is not None)

        print(f"Clustering stats:")
        print(f"  Items with cluster_id: {clustered_count}/{len(reddit_items)}")
        print(f"  Items marked as primary: {primary_count}/{len(reddit_items)}")
        print(f"  Items without cluster_id: {len(reddit_items) - clustered_count}")

        # Show details for each item
        print_header("Reddit Item Details")

        for i, item in enumerate(reddit_items, 1):
            print(f"\n{i}. {item.title[:80]}...")
            print(f"   ID: {item.id}")
            print(f"   Source Type: '{item.source_type}'")
            print(f"   Customer ID: {item.customer_id}")
            print(f"   Published: {item.published_date}")
            print(f"   Cluster ID: {item.cluster_id}")
            print(f"   Is Primary: {item.is_cluster_primary}")
            print(f"   Cluster Members: {item.cluster_member_count}")

            if item.raw_data and 'subreddit' in item.raw_data:
                print(f"   Subreddit: r/{item.raw_data['subreddit']}")

    except Exception as e:
        print_error(f"Error: {e}")
        import traceback
        traceback.print_exc()
    finally:
        db.close()


def cmd_reddit_processed(args):
    """Check Reddit processing status"""
    print_header("Reddit Items Processing Status")

    db = SessionLocal()
    try:
        reddit_items = db.query(IntelligenceItem).filter(
            IntelligenceItem.source_type == 'reddit'
        ).all()

        print(f"Total Reddit items: {Colors.BOLD}{len(reddit_items)}{Colors.ENDC}\n")

        if not reddit_items:
            print_warning("No Reddit items found")
            return

        # Check processing status
        processed_count = 0
        unrelated_count = 0
        categories = {}

        for item in reddit_items:
            processed = db.query(ProcessedIntelligence).filter(
                ProcessedIntelligence.item_id == item.id
            ).first()

            print(f"\n{Colors.BOLD}{'='*60}{Colors.ENDC}")
            print(f"Item {item.id}: {item.title[:60]}...")
            print(f"{Colors.BOLD}{'='*60}{Colors.ENDC}")
            print(f"  is_cluster_primary: {item.is_cluster_primary}")

            if processed:
                processed_count += 1
                print_success("PROCESSED")
                print(f"     Category: {processed.category}")
                print(f"     Sentiment: {processed.sentiment}")
                print(f"     Priority: {processed.priority_score}")

                cat = processed.category or 'None'
                categories[cat] = categories.get(cat, 0) + 1

                if processed.category == 'unrelated':
                    unrelated_count += 1
                    print_warning("FILTERED OUT (category=unrelated)")
            else:
                print_error("NOT PROCESSED")

        # Summary
        print_header("Summary")
        print(f"Total Reddit items: {len(reddit_items)}")
        print(f"Processed: {processed_count}")
        print(f"Unprocessed: {len(reddit_items) - processed_count}")
        print(f"Categorized as 'unrelated': {unrelated_count}")

        if categories:
            print(f"\nCategories breakdown:")
            for cat, count in sorted(categories.items(), key=lambda x: x[1], reverse=True):
                print(f"  {cat}: {count}")

    except Exception as e:
        print_error(f"Error: {e}")
        import traceback
        traceback.print_exc()
    finally:
        db.close()


def cmd_api_feed(args):
    """Test API feed endpoint"""
    print_header("Feed API Test")

    db = SessionLocal()
    try:
        # Get customers
        customers = db.query(Customer).all()
        print("Customers in database:")
        for customer in customers:
            print(f"  ID {customer.id}: {customer.name}")

        # Find customer
        if args.customer:
            customer = db.query(Customer).filter(Customer.name.ilike(f"%{args.customer}%")).first()
            if not customer:
                print_error(f"Customer '{args.customer}' not found!")
                return
        else:
            # Default to first customer
            customer = customers[0] if customers else None
            if not customer:
                print_error("No customers in database!")
                return

        print(f"\n{Colors.BOLD}Testing feed for: {customer.name} (ID: {customer.id}){Colors.ENDC}")

        # Test clustered=True (Smart Feed)
        print_header("Smart Feed (clustered=True)")

        query = db.query(IntelligenceItem).join(
            ProcessedIntelligence,
            IntelligenceItem.id == ProcessedIntelligence.item_id,
            isouter=True
        )

        filters = [
            IntelligenceItem.customer_id == customer.id,
            IntelligenceItem.is_cluster_primary == True
        ]

        query = query.filter(and_(*filters))
        items = query.order_by(desc(IntelligenceItem.published_date)).limit(50).all()

        print(f"Total items returned by API: {len(items)}")

        # Apply frontend filter (removes unrelated)
        filtered_items = [
            item for item in items
            if not db.query(ProcessedIntelligence).filter(
                ProcessedIntelligence.item_id == item.id,
                ProcessedIntelligence.category == 'unrelated'
            ).first()
        ]

        print(f"After frontend 'unrelated' filter: {len(filtered_items)} items")

        # Show Reddit items
        reddit_items = [item for item in filtered_items if item.source_type == 'reddit']
        print(f"\n{Colors.BOLD}Reddit items in Smart Feed: {len(reddit_items)}{Colors.ENDC}")
        for item in reddit_items:
            print(f"  - {item.title[:60]}...")

        # Test clustered=False (Full Feed)
        print_header("Full Feed (clustered=False)")

        query = db.query(IntelligenceItem).join(
            ProcessedIntelligence,
            IntelligenceItem.id == ProcessedIntelligence.item_id,
            isouter=True
        )

        filters = [IntelligenceItem.customer_id == customer.id]
        query = query.filter(and_(*filters))
        items = query.order_by(desc(IntelligenceItem.published_date)).limit(50).all()

        print(f"Total items returned by API: {len(items)}")

        filtered_items = [
            item for item in items
            if not db.query(ProcessedIntelligence).filter(
                ProcessedIntelligence.item_id == item.id,
                ProcessedIntelligence.category == 'unrelated'
            ).first()
        ]

        print(f"After frontend 'unrelated' filter: {len(filtered_items)} items")

        # Show Reddit items
        reddit_items = [item for item in filtered_items if item.source_type == 'reddit']
        print(f"\n{Colors.BOLD}Reddit items in Full Feed: {len(reddit_items)}{Colors.ENDC}")
        for item in reddit_items:
            processed = db.query(ProcessedIntelligence).filter(
                ProcessedIntelligence.item_id == item.id
            ).first()
            print(f"  - {item.title[:60]}... (primary: {item.is_cluster_primary})")

    except Exception as e:
        print_error(f"Error: {e}")
        import traceback
        traceback.print_exc()
    finally:
        db.close()


